# ---- Slack ----
# Bot token (starts with xoxb-) for the Client Response Time Tracker app.
# Create the app, add scopes, install to workspace, copy the Bot User OAuth Token.
SLACK_BOT_TOKEN=xoxb-your-token-here

# ---- Google Sheets output ----
# The scorecard / results spreadsheet ID (from its URL).
RESULTS_SPREADSHEET_ID=your-spreadsheet-id-here
# Tab name the tracker writes the weekly metric + breakdown into.
RESULTS_TAB=Response Time

# Service-account JSON lives next to this file as credentials.json
# (same pattern as the Performance Dashboard). Share the sheet with the
# service account's client_email and give it Editor access.
